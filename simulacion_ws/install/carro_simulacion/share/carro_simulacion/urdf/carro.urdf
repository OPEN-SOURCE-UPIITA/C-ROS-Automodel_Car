<?xml version="1.0"?>
<robot name="Carros">

  <material name="aston_martin_green"><color rgba="0.0 0.35 0.28 1.0"/></material>
  <material name="black"><color rgba="0 0 0 1"/></material>
  <material name="silver"><color rgba="0.75 0.75 0.75 1"/></material>
  <material name="blue"><color rgba="0 0 1 1"/></material>

  <link name="base_link">
    <visual>
      <origin xyz="-0.43 0.195 0.11" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://carro_simulacion/meshes/chasis-Assembly2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="aston_martin_green"/>
    </visual>
    <collision>
      <origin xyz="-0.43 0.195 0.11" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://carro_simulacion/meshes/chasis-Assembly2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.5"/> 
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <link name="front_left_steering_link">
    <inertial><mass value="0.1"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
  </link>
  <joint name="front_left_steering_joint" type="revolute">
    <parent link="base_link"/><child link="front_left_steering_link"/>
    <axis xyz="0 0 1"/><limit lower="-0.6" upper="0.6" effort="100" velocity="1.0"/>
    <origin xyz="0.135 0.075 0" rpy="0 0 0"/>
  </joint>

  <link name="front_left_wheel">
    <visual><origin xyz="0 0 0" rpy="1.5708 0 0"/><geometry><cylinder length="0.026" radius="0.034"/></geometry><material name="black"/></visual>
    <collision><origin xyz="0 0 0" rpy="1.5708 0 0"/><geometry><cylinder length="0.026" radius="0.034"/></geometry></collision>
    <inertial><mass value="0.2"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
  </link>
  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="front_left_steering_link"/><child link="front_left_wheel"/>
    <axis xyz="0 1 0"/><origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="front_right_steering_link">
    <inertial><mass value="0.1"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
  </link>
  <joint name="front_right_steering_joint" type="revolute">
    <parent link="base_link"/><child link="front_right_steering_link"/>
    <axis xyz="0 0 1"/><limit lower="-0.6" upper="0.6" effort="100" velocity="1.0"/>
    <origin xyz="0.135 -0.075 0" rpy="0 0 0"/>
  </joint>

  <link name="front_right_wheel">
    <visual><origin xyz="0 0 0" rpy="1.5708 0 0"/><geometry><cylinder length="0.026" radius="0.034"/></geometry><material name="black"/></visual>
    <collision><origin xyz="0 0 0" rpy="1.5708 0 0"/><geometry><cylinder length="0.026" radius="0.034"/></geometry></collision>
    <inertial><mass value="0.2"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
  </link>
  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="front_right_steering_link"/><child link="front_right_wheel"/>
    <axis xyz="0 1 0"/><origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="rear_left_wheel">
    <visual><origin xyz="0 0 0" rpy="1.5708 0 0"/><geometry><cylinder length="0.026" radius="0.034"/></geometry><material name="black"/></visual>
    <collision><origin xyz="0 0 0" rpy="1.5708 0 0"/><geometry><cylinder length="0.026" radius="0.034"/></geometry></collision>
    <inertial><mass value="0.2"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
  </link>
  <joint name="rear_left_joint" type="continuous">
    <parent link="base_link"/><child link="rear_left_wheel"/>
    <axis xyz="0 1 0"/><origin xyz="-0.14 0.075 0" rpy="0 0 0"/>
  </joint>

  <link name="rear_right_wheel">
    <visual><origin xyz="0 0 0" rpy="1.5708 0 0"/><geometry><cylinder length="0.026" radius="0.034"/></geometry><material name="black"/></visual>
    <collision><origin xyz="0 0 0" rpy="1.5708 0 0"/><geometry><cylinder length="0.026" radius="0.034"/></geometry></collision>
    <inertial><mass value="0.2"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
  </link>
  <joint name="rear_right_joint" type="continuous">
    <parent link="base_link"/><child link="rear_right_wheel"/>
    <axis xyz="0 1 0"/><origin xyz="-0.14 -0.075 0" rpy="0 0 0"/>
  </joint>

  <link name="lidar_link">
    <visual><geometry><cylinder radius="0.03" length="0.04"/></geometry><material name="blue"/></visual>
    <inertial><mass value="0.1"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/><child link="lidar_link"/>
    <origin xyz="-0.08 0 0.12" rpy="0 0 0"/>
  </joint>

  <link name="camera_link">
    <visual><geometry><box size="0.02 0.1 0.03"/></geometry><material name="black"/></visual>
  </link>
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/><child link="camera_link"/>
    <origin xyz="-0.02 0 0.11" rpy="0 0 0"/>
  </joint>

  <link name="camera_link_optical"></link>
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/><child link="camera_link_optical"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>

  <gazebo>
    <plugin filename="gz-sim-ackermann-steering-system" name="gz::sim::systems::AckermannSteering">
      <left_steering_joint>front_left_steering_joint</left_steering_joint>
      <right_steering_joint>front_right_steering_joint</right_steering_joint>
      <left_joint>rear_left_joint</left_joint>
      <right_joint>rear_right_joint</right_joint>
      <wheel_separation>0.15</wheel_separation>
      <wheel_radius>0.034</wheel_radius>
      <topic>/model/carro/cmd_vel</topic>
      <odom_topic>/odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
    </plugin>
  </gazebo>

  <gazebo reference="base_link">
    <material>
      <ambient>0.0 0.2 0.15 1.0</ambient>
      <diffuse>0.0 0.35 0.28 1.0</diffuse>
      <specular>0.8 0.8 0.8 1.0</specular>
      <pbr><metal><metalness>0.7</metalness><roughness>0.2</roughness></metal></pbr>
    </material>
  </gazebo>

  <gazebo reference="front_left_wheel"><mu1>0.9</mu1><mu2>0.9</mu2><material>Gazebo/Black</material></gazebo>
  <gazebo reference="front_right_wheel"><mu1>0.9</mu1><mu2>0.9</mu2><material>Gazebo/Black</material></gazebo>
  <gazebo reference="rear_left_wheel"><mu1>0.9</mu1><mu2>0.9</mu2><material>Gazebo/Black</material></gazebo>
  <gazebo reference="rear_right_wheel"><mu1>0.9</mu1><mu2>0.9</mu2><material>Gazebo/Black</material></gazebo>

  <gazebo reference="lidar_link">
    <sensor name="gpu_lidar" type="gpu_lidar">
      <pose>0 0 0 0 0 0</pose>
      <always_on>1</always_on>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <lidar>
        <scan>
          <horizontal>
            <samples>640</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min> <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
      </lidar>
      <topic>/model/carro/scan</topic> 
      <gz_frame_id>lidar_link</gz_frame_id>
    </sensor>
  </gazebo>

  <gazebo reference="camera_link">
    <sensor name="rgbd_camera" type="rgbd">
      <always_on>1</always_on>
      <update_rate>30</update_rate>
      <visualize>true</visualize>
      <topic>camera</topic>
      <camera>
        <horizontal_fov>1.288</horizontal_fov> <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip><near>0.2</near><far>4.0</far></clip>
      </camera>
      <gz_frame_id>camera_link_optical</gz_frame_id>
    </sensor>
  </gazebo>

</robot>